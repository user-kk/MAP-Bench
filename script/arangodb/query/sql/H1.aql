FOR ad IN author_doc
  FILTER "__MB_author_name__" in ad.doc.display_name_alternatives
  for a in author
    filter ad.id == a.id
      for w in inbound concat("author_v/",to_string(a.id)) work_author_e
      collect id = a.id, author_name = a.display_name into titles = w.title
      let unique_titles = UNIQUE(titles)
      sort id
      RETURN {
        id: id,
        author_name: author_name,
        titles: unique_titles,         
        paper_cnt: LENGTH(unique_titles)
      }