let topic_ids = (
    for t in topic
        filter t.subfield_display_name == '__MB_topic_name__'
        RETURN t.id
)

LET ai_papers = (
    for wd in work_doc
        filter wd.doc.topics[*].id any in topic_ids
        FILTER has(wd.doc.abstract_inverted_index,'LLM') or has(wd.doc.abstract_inverted_index,'transformer')
        FOR w IN work
            filter w.id == wd.id
            FILTER w.publication_year >= 2022 AND w.publication_year <= 2025
            RETURN {work_id:w.id,cited_by_count:w.cited_by_count}
)
LET author_counts = (
    FOR p IN ai_papers
        for wd in work_doc
            filter p.work_id == wd.id and wd.doc.authorships != null
            FOR authorship IN wd.doc.authorships
                COLLECT author_id = authorship.author.id INTO works = p
                
                // 计算 pub_count (去重后的论文数)
                LET pub_count = LENGTH(UNIQUE(works[*].work_id))

                LET i10_index = LENGTH(UNIQUE(
                    FOR w IN works 
                    FILTER w.cited_by_count >= 10 
                    RETURN w.work_id
                ))
                
                RETURN { author_id, pub_count, i10_index }
)
FOR ac IN author_counts
    for a in author
        filter ac.author_id == a.id AND a.works_count != 0 and a.cited_by_count >= 10000
        let ratio = ac.pub_count/a.works_count
        SORT ac.i10_index DESC,ratio DESC,ac.author_id ASC
        LIMIT 10
        RETURN {
            author_id: ac.author_id,
            display_name: a.display_name,
            i10_index: ac.i10_index,
            ratio:ratio
        }